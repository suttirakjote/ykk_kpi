<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_ykk_kpi_group_position_search" model="ir.ui.view">
        <field name="name">ykk.kpi.group.position.search</field>
        <field name="model">ykk.kpi.group.position</field>
        <field name="arch" type="xml">
            <search string="Group Positions">
                <field name="name"/>
                <separator/>
                <filter name="active" string="Active" domain="[('active', '=', True)]"/>
                <filter name="inactive" string="Inactive" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="view_ykk_kpi_group_position_list" model="ir.ui.view">
        <field name="name">ykk.kpi.group.position.list</field>
        <field name="model">ykk.kpi.group.position</field>
        <field name="arch" type="xml">
            <list string="Group Positions" sample="1" editable="bottom" multi_edit="1">
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="action_kpi_group_position" model="ir.actions.act_window">
        <field name="name">Group Positions</field>
        <field name="res_model">ykk.kpi.group.position</field>
        <field name="view_mode">list</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Group Position.
            </p>
        </field>
    </record>

    <menuitem id="menu_ykk_kpi_group_position"
        name="Group Positions"
        parent="menu_ykk_kpi_configuration"
        action="action_kpi_group_position"
        sequence="80"/>
</odoo>
