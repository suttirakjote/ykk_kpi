<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_ykk_kpi_hr_evaluation_search" model="ir.ui.view">
        <field name="name">ykk.kpi.hr.evaluation.search</field>
        <field name="model">ykk.kpi.hr.evaluation</field>
        <field name="arch" type="xml">
            <search string="HR Evaluation">
                <field name="code"/>
                <field name="name"/>
                <field name="type"/>
                <field name="department_id"/>
                <separator/>
                <filter name="active" string="Active" domain="[('active', '=', True)]"/>
                <filter name="inactive" string="Inactive" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_type" string="Type" context="{'group_by': 'type'}"/>
                    <filter name="group_by_group_type" string="Group Type" context="{'group_by': 'group_type'}"/>
                    <filter name="group_by_department" string="Department" context="{'group_by': 'department_id'}"/>
                    <filter name="group_by_company" string="Company" context="{'group_by': 'company_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_ykk_kpi_hr_evaluation_list" model="ir.ui.view">
        <field name="name">ykk.kpi.hr.evaluation.list</field>
        <field name="model">ykk.kpi.hr.evaluation</field>
        <field name="arch" type="xml">
            <list string="HR Evaluations" sample="1" editable="bottom" multi_edit="1">
                <field name="code"/>
                <field name="name"/>
                <field name="type" optional="show"/>
                <field name="department_id" options="{'no_create': True}" optional="show"/>
                <field name="group_type" optional="show"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="action_kpi_hr_evaluation" model="ir.actions.act_window">
        <field name="name">HR Evaluations</field>
        <field name="res_model">ykk.kpi.hr.evaluation</field>
        <field name="view_mode">list</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Human Resource Evaluation configuration.
            </p>
        </field>
    </record>

    <menuitem id="menu_ykk_kpi_hr_evaluation"
        name="HR Evaluations"
        parent="menu_ykk_kpi_configuration"
        action="action_kpi_hr_evaluation"
        sequence="15"/>
</odoo>
