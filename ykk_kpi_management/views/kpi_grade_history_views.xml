<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_kpi_grade_history_list" model="ir.ui.view">
        <field name="name">kpi.grade.history.list</field>
        <field name="model">kpi.grade.history</field>
        <field name="arch" type="xml">
            <list create="0" edit="0">
                <field name="create_date"/>
                <field name="employee_id"/>
                <field name="period_id"/>
                <field name="old_grade"/>
                <field name="new_grade"/>
                <field name="changed_by"/>
            </list>
        </field>
    </record>

    <record id="action_kpi_grade_history" model="ir.actions.act_window">
        <field name="name">Grade History</field>
        <field name="res_model">kpi.grade.history</field>
        <field name="view_mode">list</field>
    </record>
</odoo>
