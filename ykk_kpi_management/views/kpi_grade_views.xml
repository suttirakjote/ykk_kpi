<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_ykk_kpi_grade_search" model="ir.ui.view">
        <field name="name">ykk.kpi.grade.search</field>
        <field name="model">ykk.kpi.grade</field>
        <field name="arch" type="xml">
            <search string="Grades">
                <field name="name"/>
                <separator/>
                <filter name="active" string="Active" domain="[('active', '=', True)]"/>
                <filter name="inactive" string="Inactive" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="view_ykk_kpi_grade_list" model="ir.ui.view">
        <field name="name">ykk.kpi.grade.list</field>
        <field name="model">ykk.kpi.grade</field>
        <field name="arch" type="xml">
            <list string="Grades" sample="1" editable="bottom" multi_edit="1">
                <field name="code"/>
                <field name="name"/>
                <field name="start_score"/>
                <field name="end_score"/>
                <field name="grade_score"/>
                <field name="plus_minus"/>
                <field name="description" optional="show"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="action_kpi_grade" model="ir.actions.act_window">
        <field name="name">Grades</field>
        <field name="res_model">ykk.kpi.grade</field>
        <field name="view_mode">list</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Grade configuration.
            </p>
        </field>
    </record>

    <menuitem id="menu_ykk_kpi_grade"
        name="Grades"
        parent="menu_ykk_kpi_configuration"
        action="action_kpi_grade"
        sequence="20"/>
</odoo>
