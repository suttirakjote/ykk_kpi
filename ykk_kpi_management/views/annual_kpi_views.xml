<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_ykk_kpi_annual_kpi_search" model="ir.ui.view">
        <field name="name">ykk.kpi.annual.kpi.search</field>
        <field name="model">ykk.kpi.annual.kpi</field>
        <field name="arch" type="xml">
            <search string="Annual KPI">
                <field name="employee_id"/>
                <field name="group_position_id"/>
                <field name="level_id"/>
                <field name="department_id"/>
                <field name="responsible_id"/>
                <separator/>
                <filter string="Date" name="date" date="date"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_employee" string="Employee" context="{'group_by': 'employee_id'}"/>
                    <filter name="group_by_group_position" string="Group Position" context="{'group_by': 'group_position_id'}"/>
                    <filter name="group_by_level" string="Level" context="{'group_by': 'level_id'}"/>
                    <filter name="group_by_department" string="Department" context="{'group_by': 'department_id'}"/>
                    <filter name="group_by_responsible" string="Responsible" context="{'group_by': 'responsible_id'}"/>
                    <filter name="group_by_company" string="Company" context="{'group_by': 'company_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_ykk_kpi_annual_kpi_list" model="ir.ui.view">
        <field name="name">ykk.kpi.annual.kpi.list</field>
        <field name="model">ykk.kpi.annual.kpi</field>
        <field name="arch" type="xml">
            <list string="Annual KPI" sample="1">
                <field name="name"/>
                <field name="employee_id" widget="many2one_avatar_employee"/>
                <field name="group_position_id" optional="show"/>
                <field name="level_id" optional="show"/>
                <field name="department_id" optional="show"/>
                <field name="period_ids" widget="many2many_tags" optional="show"/>
                <field name="responsible_id" widget="many2one_avatar_user"/>
                <field name="activity_ids" widget="list_activity"/>
                <field name="state" widget="badge" 
                    decoration-info="state == 'draft'"
                    decoration-warning="state == 'inprocess'"
                    decoration-success="state == 'done'"/>
            </list>
        </field>
    </record>

    <record id="view_ykk_kpi_annual_kpi_form" model="ir.ui.view">
        <field name="name">ykk.kpi.annual.kpi.form</field>
        <field name="model">ykk.kpi.annual.kpi</field>
        <field name="arch" type="xml">
            <form string="Annual KPI">
                <header>
                    <button name="action_inprocess" string="Inprocess" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_done" string="Done" type="object" class="btn-primary" invisible="state != 'inprocess'"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state == 'cancel'"/>
                    <button name="action_draft" string="Reset to Draft" type="object" invisible="state != 'cancel'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,inprocess,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="employee_id" widget="many2one_avatar_employee" options="{'no_create': True}"/>
                            <field name="group_position_id" options="{'no_create': True}"/>
                            <field name="level_id" options="{'no_create': True}"/>
                            <field name="department_id" options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="template_id" options="{'no_create': True}"/>
                            <field name="period_ids" widget="many2many_tags" options="{'no_create': True}"/>
                            <field name="date"/>
                            <field name="responsible_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Performance Evaluation">
                            <field name="performance_line_ids">
                                <list editable="bottom">
                                    <field name="goal_id" options="{'no_create': True}" domain="[('type', '=', 'performance')]"/>
                                    <field name="achievement_criteria"/>
                                    <field name="weight" sum="Total Weight"/>
                                </list>
                            </field>
                        </page>
                        <page string="Role-based Behavior Evaluation">
                            <field name="role_line_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="achievement_criteria"/>
                                    <field name="weight" sum="Total Weight"/>
                                </list>
                            </field>
                        </page>
                        <page string="Behavior Evaluation">
                            <field name="behavior_line_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="achievement_criteria"/>
                                    <field name="weight" sum="Total Weight"/>
                                </list>
                            </field>
                        </page>
                        <page string="Attitude Evaluation">
                            <field name="attitude_line_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="achievement_criteria"/>
                                    <field name="weight" sum="Total Weight"/>
                                </list>
                            </field>
                        </page>
                        <page string="Other Info">
                            <group string="Indicator Weight">
                                <group>
                                    <field name="performance_weight"/>
                                    <field name="role_based_behavior_weight"/>
                                    <field name="behavior_weight"/>
                                    <field name="attitude_weight"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_annual_kpi" model="ir.actions.act_window">
        <field name="name">Annual KPI</field>
        <field name="res_model">ykk.kpi.annual.kpi</field>
        <field name="view_mode">list,form,activity</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Annual KPI.
            </p>
        </field>
    </record>

    <menuitem id="menu_ykk_kpi_annual_kpi"
        name="Annual KPI"
        parent="menu_ykk_kpi_evaluate"
        action="action_annual_kpi"
        sequence="10"/>
</odoo>
