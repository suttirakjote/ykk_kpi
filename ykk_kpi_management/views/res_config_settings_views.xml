<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_form_ykk_kpi" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.ykk.kpi</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="hr.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@name='employees_setting_container']" position="inside">
                <setting id="ykk_company_working_day_setting"
                    string="Company Working Day"
                    help="Number of working days per month, used in salary calculation for Daily employees.">
                    <field name="ykk_company_working_day"/>
                </setting>
            </xpath>
        </field>
    </record>

</odoo>
