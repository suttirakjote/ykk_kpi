<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="module_category_ykk_kpi" model="ir.module.category">
        <field name="name">KPI</field>
        <field name="sequence">20</field>
    </record>

    <record id="group_ykk_kpi_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="module_category_ykk_kpi"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_ykk_kpi_admin" model="res.groups">
        <field name="name">Administrator</field>
        <field name="category_id" ref="module_category_ykk_kpi"/>
        <field name="implied_ids" eval="[(4, ref('group_ykk_kpi_user'))]"/>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

</odoo>
