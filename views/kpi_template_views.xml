<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_ykk_kpi_template_search" model="ir.ui.view">
        <field name="name">ykk.kpi.template.search</field>
        <field name="model">ykk.kpi.template</field>
        <field name="arch" type="xml">
            <search string="Template KPI">
                <field name="name"/>
                <field name="level_id"/>
                <field name="department_id"/>
                <field name="state"/>
                <separator/>
                <filter string="Date" name="date" date="date"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_level" string="Level" context="{'group_by': 'level_id'}"/>
                    <filter name="group_by_department" string="Department" context="{'group_by': 'department_id'}"/>
                    <filter name="group_by_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_by_company" string="Company" context="{'group_by': 'company_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_ykk_kpi_template_list" model="ir.ui.view">
        <field name="name">ykk.kpi.template.list</field>
        <field name="model">ykk.kpi.template</field>
        <field name="arch" type="xml">
            <list string="Template KPI" sample="1">
                <field name="name"/>
                <field name="level_id" optional="show"/>
                <field name="department_id" optional="show"/>
                <field name="date"/>
                <field name="state" widget="badge" 
                    decoration-info="state == 'draft'"
                    decoration-success="state == 'done'"/>
            </list>
        </field>
    </record>

    <record id="view_ykk_kpi_template_form" model="ir.ui.view">
        <field name="name">ykk.kpi.template.form</field>
        <field name="model">ykk.kpi.template</field>
        <field name="arch" type="xml">
            <form string="Template KPI">
                <header>
                    <button name="action_done" string="Done" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state == 'cancel'"/>
                    <button name="action_draft" string="Reset to Draft" type="object" invisible="state != 'cancel'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="level_id" options="{'no_create': True}" readonly="state != 'draft'"/>
                            <field name="department_id" options="{'no_create': True}" readonly="state != 'draft'"/>
                            <field name="remark" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="date" readonly="state != 'draft'"/>
                            <field name="responsible_id" widget="many2one_avatar_user" readonly="state != 'draft'"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Performance Evaluation">
                            <field name="performance_line_ids" readonly="state != 'draft'">
                                <list editable="bottom">
                                    <field name="goal_id" options="{'no_create': True}" domain="[('type', '=', 'performance')]"/>
                                    <field name="achievement_criteria"/>
                                    <field name="weight" sum="Total Weight"/>
                                </list>
                            </field>
                        </page>
                        <page string="Employees">
                            <field name="employee_ids" domain="[('department_id', '=', department_id), ('ykk_kpi_level_id', '=', level_id)]" readonly="state != 'draft'">
                                <list>
                                    <field name="name"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_kpi_template" model="ir.actions.act_window">
        <field name="name">Template KPI</field>
        <field name="res_model">ykk.kpi.template</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Template KPI.
            </p>
        </field>
    </record>

    <menuitem id="menu_ykk_kpi_template"
        name="Template KPI"
        parent="menu_ykk_kpi_configuration"
        action="action_kpi_template"
        sequence="5"/>
</odoo>
