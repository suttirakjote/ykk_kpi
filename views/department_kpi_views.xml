<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_ykk_kpi_department_kpi_search" model="ir.ui.view">
        <field name="name">ykk.kpi.department.kpi.search</field>
        <field name="model">ykk.kpi.department.kpi</field>
        <field name="arch" type="xml">
            <search string="Department KPI">
                <field name="employee_id"/>
                <field name="group_position_id"/>
                <field name="level_id"/>
                <field name="department_id"/>
                <field name="period_id"/>
                <field name="responsible_id"/>
                <field name="state"/>
                <separator/>
                <filter string="Date" name="date" date="date"/>
                <group expand="0" string="Group By">
                    <filter name="group_by_employee" string="Employee" context="{'group_by': 'employee_id'}"/>
                    <filter name="group_by_group_position" string="Group Position" context="{'group_by': 'group_position_id'}"/>
                    <filter name="group_by_level" string="Level" context="{'group_by': 'level_id'}"/>
                    <filter name="group_by_department" string="Department" context="{'group_by': 'department_id'}"/>
                    <filter name="group_by_period" string="Period" context="{'group_by': 'period_id'}"/>
                    <filter name="group_by_responsible" string="Responsible" context="{'group_by': 'responsible_id'}"/>
                    <filter name="group_by_state" string="Status" context="{'group_by': 'state'}"/>
                    <filter name="group_by_company" string="Company" context="{'group_by': 'company_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_ykk_kpi_department_kpi_list" model="ir.ui.view">
        <field name="name">ykk.kpi.department.kpi.list</field>
        <field name="model">ykk.kpi.department.kpi</field>
        <field name="arch" type="xml">
            <list string="Department KPI" sample="1">
                <field name="name"/>
                <field name="employee_id" widget="many2one_avatar_employee"/>
                <field name="group_position_id" optional="show"/>
                <field name="level_id" optional="show"/>
                <field name="department_id" optional="show"/>
                <field name="period_id" optional="show"/>
                <field name="date"/>
                <field name="responsible_id" widget="many2one_avatar_user"/>
                <field name="activity_ids" widget="list_activity"/>
                <field name="state" widget="badge"
                    decoration-info="state == 'draft'"
                    decoration-warning="state == 'inprocess'"
                    decoration-success="state == 'evaluated'"/>
            </list>
        </field>
    </record>

    <record id="view_ykk_kpi_department_kpi_form" model="ir.ui.view">
        <field name="name">ykk.kpi.department.kpi.form</field>
        <field name="model">ykk.kpi.department.kpi</field>
        <field name="arch" type="xml">
            <form string="Department KPI">
                <header>
                    <button name="action_confirm" string="Confirm" type="object" class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_done" string="Done" type="object" class="btn-primary" invisible="state != 'inprocess'"/>
                    <button name="action_cancel" string="Cancel" type="object" invisible="state not in ('draft', 'inprocess')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,inprocess,evaluated"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="employee_id" widget="many2one_avatar_employee" options="{'no_create': True}"/>
                            <field name="group_position_id" options="{'no_create': True}"/>
                            <field name="level_id" options="{'no_create': True}"/>
                            <field name="department_id" options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="period_id" options="{'no_create': True}"/>
                            <field name="date"/>
                            <!-- <field name="responsible_id" widget="many2one_avatar_user" options="{'no_create': True}"/> -->
                            <field name="annual_id" options="{'no_create': True}"/>
                            <field name="total_score"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Performance Evaluation">
                            <field name="performance_line_ids">
                                <list editable="bottom">
                                    <field name="goal_id" options="{'no_create': True}"/>
                                    <field name="achievement_criteria"/>
                                    <field name="weight"/>
                                    <field name="performance_result"/>
                                    <field name="first_evaluator_comment"/>
                                    <field name="first_evaluator_score"/>
                                    <field name="second_evaluator_score"/>
                                    <field name="total_score"/>
                                </list>
                            </field>
                        </page>

                        <page string="Role-based Behavior Evaluation">
                            <field name="role_line_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="achievement_criteria"/>
                                    <field name="weight"/>
                                    <field name="performance_result"/>
                                    <field name="first_evaluator_comment"/>
                                    <field name="first_evaluator_score"/>
                                    <field name="second_evaluator_score"/>
                                    <field name="total_score"/>
                                </list>
                            </field>
                        </page>
                        <page string="Behavior Evaluation">
                            <field name="behavior_line_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="achievement_criteria"/>
                                    <field name="weight"/>
                                    <field name="performance_result"/>
                                    <field name="first_evaluator_comment"/>
                                    <field name="first_evaluator_score"/>
                                    <field name="second_evaluator_score"/>
                                    <field name="total_score"/>
                                </list>
                            </field>
                        </page>
                        <page string="Attitude Evaluation">
                            <field name="attitude_line_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="achievement_criteria"/>
                                    <field name="weight"/>
                                    <field name="performance_result"/>
                                    <field name="first_evaluator_comment"/>
                                    <field name="first_evaluator_score"/>
                                    <field name="second_evaluator_score"/>
                                    <field name="total_score"/>
                                </list>
                            </field>
                        </page>
                        <page string="Summary">
                            <group col="2">
                                <group string="Parent KPI">
                                    <field name="summary_parent_kpi_ids">
                                        <list editable="bottom">
                                            <field name="parent_kpi_id" domain="[('id', '!=', parent.id)]" options="{'no_create': True}"/>
                                            <field name="grade_id" readonly="1"/>
                                        </list>
                                    </field>
                                </group>
                                <group string="Grades">
                                    <field name="period_grade_id" readonly="1"/>
                                    <field name="overall_grade_id" readonly="1"/>
                                    <field name="period_score" readonly="1" invisible="1"/>
                                    <field name="overall_score" readonly="1" invisible="1"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_department_kpi" model="ir.actions.act_window">
        <field name="name">Department KPI</field>
        <field name="res_model">ykk.kpi.department.kpi</field>
        <field name="view_mode">list,form,activity</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Department KPI.
            </p>
        </field>
    </record>

    <menuitem id="menu_ykk_kpi_department_kpi"
        name="Department KPI"
        parent="menu_ykk_kpi_evaluate"
        action="action_department_kpi"
        sequence="20"/>
</odoo>
