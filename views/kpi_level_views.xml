<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_ykk_kpi_level_search" model="ir.ui.view">
        <field name="name">ykk.kpi.level.search</field>
        <field name="model">ykk.kpi.level</field>
        <field name="arch" type="xml">
            <search string="Job Levels">
                <field name="name"/>
                <field name="group_position_id"/>
                <separator/>
                <filter name="active" string="Active" domain="[('active', '=', True)]"/>
                <filter name="inactive" string="Inactive" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <record id="view_ykk_kpi_level_list" model="ir.ui.view">
        <field name="name">ykk.kpi.level.list</field>
        <field name="model">ykk.kpi.level</field>
        <field name="arch" type="xml">
            <list string="Job Levels" sample="1" editable="bottom" multi_edit="1">
                <field name="name"/>
                <field name="merit" optional="show"/>
                <field name="att" optional="show"/>
                <field name="min_salary" optional="show"/>
                <field name="max_salary" optional="show"/>
                <field name="group_position_id" options="{'no_create': True}" optional="show"/>
                <field name="description" optional="show"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="action_kpi_level" model="ir.actions.act_window">
        <field name="name">Job Levels</field>
        <field name="res_model">ykk.kpi.level</field>
        <field name="view_mode">list</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Level.
            </p>
        </field>
    </record>

    <menuitem id="menu_ykk_kpi_level"
        name="Job Levels"
        parent="menu_ykk_kpi_configuration"
        action="action_kpi_level"
        sequence="90"/>
</odoo>
