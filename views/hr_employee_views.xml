<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_employee_form_ykk_kpi" model="ir.ui.view">
        <field name="name">hr.employee.form.ykk.kpi</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">

            <xpath expr="(//field[@name='work_email'])[1]" position="before">
                <field name="ykk_employee_code"/>
            </xpath>
            <xpath expr="//notebook" position="inside">
                <page string="KPI Details" name="ykk_kpi_details">
                    <group>
                        <group string="KPI Information">
                            <field name="ykk_kpi_salary"/>
                            <field name="ykk_kpi_level_id" options="{'no_create': True}"/>
                            <field name="ykk_kpi_group_position_id" options="{'no_create': True}"/>
                            <field name="ykk_kpi_employee_type"/>
                        </group>
                    </group>
                </page>
            </xpath>

        </field>
    </record>

</odoo>
