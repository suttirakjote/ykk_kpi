<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="seq_ykk_kpi_template" model="ir.sequence">
            <field name="name">KPI Template Sequence</field>
            <field name="code">ykk.kpi.template</field>
            <field name="prefix">KT/%(year)s/%(month)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <record id="seq_ykk_annual_kpi" model="ir.sequence">
            <field name="name">Annual KPI Sequence</field>
            <field name="code">ykk.kpi.annual.kpi</field>
            <field name="prefix">AN/%(year)s/%(month)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

    </data>
</odoo>
